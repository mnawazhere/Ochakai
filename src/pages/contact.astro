---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { EXTERNAL_LINKS } from '@/constants/external-links';

const description =
  'Get in touch with Ochakai. We partner with housing organisations in The Hague and beyond to design small-scale interventions that build neighbourly connection.';
---

<DefaultLayout title="Contact | Ochakai" description={description}>
  <section class="border-border/60 border-b">
    <div class="container py-20 md:py-28 lg:py-32">
      <div class="mx-auto max-w-3xl">
        <p
          class="text-muted-foreground mb-6 text-xs font-medium tracking-[0.18em] uppercase"
        >
          Contact — お問い合わせ
        </p>
        <h1
          class="font-display text-foreground text-4xl leading-[1.08] tracking-tight md:text-5xl lg:text-[56px] lg:leading-[1.05]"
        >
          Get in touch.
        </h1>
        <p
          class="text-muted-foreground mt-8 max-w-2xl text-lg leading-relaxed md:text-xl"
        >
          We'd love to hear what you're working on. Whether you're a housing
          organisation exploring a pilot, a researcher interested in urban
          belonging, or a practitioner who wants to collaborate — send us a
          note.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-card border-border/60 border-b">
    <div class="container py-20 md:py-28">
      <div class="mx-auto grid max-w-5xl gap-16 md:grid-cols-[2fr_1fr]">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          class="space-y-8"
        >
          <input type="hidden" name="form-name" value="contact" />

          <div>
            <label
              for="name"
              class="text-foreground mb-2 block text-sm font-medium"
            >
              Your name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="border-border bg-background text-foreground focus:border-primary block w-full border-0 border-b-2 px-0 py-3 text-base focus:outline-none"
            />
          </div>

          <div>
            <label
              for="organisation"
              class="text-foreground mb-2 block text-sm font-medium"
            >
              Organisation <span class="text-muted-foreground">(optional)</span>
            </label>
            <input
              type="text"
              id="organisation"
              name="organisation"
              class="border-border bg-background text-foreground focus:border-primary block w-full border-0 border-b-2 px-0 py-3 text-base focus:outline-none"
            />
          </div>

          <div>
            <label
              for="email"
              class="text-foreground mb-2 block text-sm font-medium"
            >
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="border-border bg-background text-foreground focus:border-primary block w-full border-0 border-b-2 px-0 py-3 text-base focus:outline-none"
            />
          </div>

          <div>
            <label
              for="message"
              class="text-foreground mb-2 block text-sm font-medium"
            >
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="border-border bg-background text-foreground focus:border-primary block w-full resize-none border-0 border-b-2 px-0 py-3 text-base focus:outline-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-12 items-center justify-center px-8 text-base font-medium transition-colors"
          >
            Send message
          </button>
        </form>

        <div class="md:border-border/60 md:border-l md:pl-10">
          <h2
            class="text-muted-foreground mb-4 text-xs font-medium tracking-[0.16em] uppercase"
          >
            Prefer email?
          </h2>
          <a
            href={EXTERNAL_LINKS.EMAIL}
            class="font-display text-foreground hover:text-primary block text-2xl leading-tight tracking-tight transition-colors"
          >
            hello@ochakai.com
          </a>
          <p class="text-muted-foreground mt-6 text-base leading-relaxed">
            We reply within a few days. If your question is about a specific
            building or pilot, including the city and rough timeline helps us
            respond well.
          </p>
          <p
            class="text-muted-foreground mt-8 text-sm tracking-wide uppercase"
            lang="ja"
          >
            The Hague · デン・ハーグ
          </p>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
